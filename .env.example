# Guitar Tutorial Manager - Environment Variables
# Copy this file to .env and adjust values for your deployment.

# Path to the tutorials directory where uploaded video/PDF files are stored.
# When running locally (mvn spring-boot:run), defaults to ./tutorials (project root).
# In Docker, set to /tutorials (mounted as a Docker volume).
# Example: /volume1/music/guitar-tutorials
TUTORIALS_DIR=./tutorials

# Host port for the frontend web UI (maps to nginx port 80 inside the container).
FRONTEND_PORT=3000

# Host port for the backend API (maps to Spring Boot port 8080 inside the container).
BACKEND_PORT=8080

# PostgreSQL database name.
DB_NAME=guitardb

# PostgreSQL database user.
DB_USER=guitar

# PostgreSQL database password.
DB_PASSWORD=guitar
