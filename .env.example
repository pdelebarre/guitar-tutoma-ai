# Guitar Tutorial Manager - Docker Compose Environment Variables
# Copy this file to .env and adjust values for your deployment.

# Path to the tutorials directory on the host machine.
# This directory will be mounted read-only into the backend container.
# Example: /volume1/music/guitar-tutorials
TUTORIALS_PATH=/path/to/your/tutorials

# Host port for the frontend web UI (maps to nginx port 80 inside the container).
FRONTEND_PORT=3000

# Host port for the backend API (maps to Spring Boot port 8080 inside the container).
BACKEND_PORT=8080

# PostgreSQL database name.
DB_NAME=guitardb

# PostgreSQL database user.
DB_USER=guitar

# PostgreSQL database password.
DB_PASSWORD=guitar
